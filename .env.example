# Documented non-secret runtime defaults live in config/runtime.yaml. Use this
# file only for local overrides, credentials, tokens and operator-specific URLs.
#
# IB Gateway paper defaults to 4002; live defaults to 4001.
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=171

# 1=live, 2=frozen, 3=delayed, 4=delayed frozen.
IBKR_MARKET_DATA_TYPE=1

# Leave empty to auto-pick the next quarterly equity futures month.
IBKR_ES_EXPIRY=
IBKR_MES_EXPIRY=

# Comma-separated verifier universe. Keep the default SPX/VIX-family focused.
# Use SYMBOL@EXCHANGE for optional cross-index checks only after entitlement is verified.
IBKR_VERIFY_INDEXES=SPX,VIX,VIX1D,VIX9D,VIX3M,VVIX,SKEW
IBKR_VERIFY_STOCKS=SPY,QQQ,IWM,DIA,HYG,LQD,TLT,IEF,SHY,UUP,GLD,USO,RSP,XLU
IBKR_VERIFY_FUTURES=ES,MES

# IBKR index CFDs. IBUS500 tracks the S&P 500 cash index and trades nearly 24h
# on weekdays. Quotes require the account to have CFD market data/trading
# permission; without it the row degrades to an entitlement error instead of
# failing the run. Leave empty to disable CFD collection.
IBKR_VERIFY_CFDS=IBUS500

# SPXW option verifier.
IBKR_OPTION_EXPIRY=
IBKR_OPTION_STRIKE_WINDOW_POINTS=50
IBKR_OPTION_STRIKE_STEP=5
IBKR_MAX_OPTION_LINES=40
IBKR_QUOTE_WAIT_SECONDS=8
IBKR_STALE_AFTER_SECONDS=10
# Slow index/ETF stale threshold (900s = 3 slow-poll cycles at 300s).
IBKR_SLOW_INDEX_STALE_AFTER_SECONDS=900
IBKR_SLOW_INDEX_LABELS=index:VIX,index:VIX1D,index:VIX9D,index:VIX3M,index:VVIX,index:SKEW,stock:QQQ,stock:IWM,stock:DIA,stock:HYG,stock:LQD,stock:TLT,stock:IEF,stock:SHY,stock:UUP,stock:GLD,stock:USO,stock:RSP,stock:XLU
IBKR_QUALIFY_CONTRACTS=true
IBKR_REQUEST_TIMEOUT_SECONDS=30

# Streaming collector (spx-spark-ibkr-stream). Keeps one persistent read-only
# connection with a hot ATM option lane plus rotating strike groups, instead of
# the connect/wait/disconnect snapshot cycle. Uses its own client id so it can
# never kick the snapshot collector's API session.
IBKR_STREAM_CLIENT_ID=172
# Two seconds keeps hot quotes fresh and advances the 28-line rotation quickly
# while remaining below IBKR's API message pacing.
IBKR_STREAM_FLUSH_SECONDS=2
IBKR_STREAM_POLICY_CHECK_SECONDS=30
IBKR_STREAM_REPLAN_DRIFT_POINTS=20
IBKR_ATM_STATE_PATH=
# Reserve the IBKR option lane for GTH SPXW. Schwab supplies SPY options, while
# IBKR keeps 56 hot + 28 rotating SPXW lines during GTH and the 15:30 ET
# next-session prefetch window. Runtime ticker-limit evidence still lowers it.
IBKR_STREAM_MAX_OPTION_LINES=84
IBKR_STREAM_SPY_OPTION_LINES=0
IBKR_STREAM_SPY_STRIKE_STEP=2
# Slow-poll lane: VIX-family indexes + context ETFs polled in chunks instead
# of persistent subscriptions. IBKR_STREAM_SLOW_POLL_LABELS defaults in code;
# set to empty string to disable and keep all base contracts subscribed.
IBKR_STREAM_SLOW_POLL_INTERVAL_SECONDS=300
IBKR_STREAM_SLOW_POLL_HOLD_SECONDS=10
IBKR_STREAM_SLOW_POLL_CHUNK_SIZE=6
IBKR_STREAM_HOT_LANE_SHARE=0.7
IBKR_STREAM_RECONNECT_MIN_SECONDS=5
IBKR_STREAM_RECONNECT_MAX_SECONDS=300
IBKR_STREAM_SKIP_OPTIONS=false
IBKR_CONFLICT_PROBE_SECONDS=5

# IBKR positions polling (optional; separate client id from stream/collector).
IBKR_POSITIONS_ENABLED=false
IBKR_POSITIONS_CLIENT_ID=174
IBKR_POSITIONS_POLL_SECONDS=60
IBKR_POSITIONS_SNAPSHOT_PATH=
IBKR_POSITIONS_STATE_PATH=
IBKR_POSITIONS_MAX_SNAPSHOT_AGE_SECONDS=180
MARKET_DATA_DELAYED_STALE_AFTER_SECONDS=60
ALERT_POSITIONS_ENABLED=true
ALERT_POSITION_STRUCTURAL_ENABLED=true
ALERT_POSITION_PNL_ENABLED=true
ALERT_POSITION_PNL_CHANGE_USD=200
ALERT_POSITION_PNL_LOSS_USD=400
ALERT_POSITION_PNL_CRITICAL_LOSS_USD=1000
ALERT_POSITION_PNL_DEDUP_BUCKET_USD=100

# IV surface movement alerts (direct push; bypass Codex).
ALERT_IV_SURFACE_SHIFT_1H_THRESHOLD=0.05
ALERT_IV_ATM_CHANGE_1H_THRESHOLD=0.04

# restart ibc-gateway when farms stay broken. Skipped in runtime protected mode.
IBKR_FARM_BROKEN_RESTART_SECONDS=180
IBKR_GATEWAY_RESTART_COOLDOWN_SECONDS=120
IBKR_AUTO_RESTART_GATEWAY_ON_FARM_BROKEN=true

# IBC-managed IB Gateway automation. Credentials live only in IBC_CONFIG, not here.
IBC_INSTALL_DIR=/home/ubuntu/apps/ibc
IBC_CONFIG=/srv/data/spx-spark/runtime/ibc/config.ini
IBC_LOG_DIR=/srv/data/spx-spark/logs/ibc
IBC_TWS_COMPAT_ROOT=/home/ubuntu/apps/ibc-ibgateway-compat
IBC_TWS_SETTINGS_PATH=/home/ubuntu/Jts
IBC_TWS_MAJOR_VRSN=
IBC_TWOFA_TIMEOUT_ACTION=restart
IBC_TRADING_MODE=

# IBC watchdog (systemd/ibc-watchdog.timer). Restarts ibc-gateway.service after
# the API port has been dead for this many consecutive 2-minute checks. It
# skips while runtime mode is "protected" or the service is disabled.
IBC_WATCHDOG_FAILURE_THRESHOLD=3

# Runtime source policy. This lets collectors try IBKR automatically after
# manual phone trading usually ends, while avoiding reconnect fights.
IBKR_SCHEDULE_ENABLED=true
IBKR_SCHEDULE_TZ=Asia/Shanghai
IBKR_SCHEDULE_START=00:00
IBKR_SCHEDULE_STOP=00:00
IBKR_CONNECT_RETRY_SECONDS=60

# 0 means: if IBKR is kicked by a competing phone/desktop session, mark IBKR
# unavailable and keep running from fallback feeds instead of trying to win.
IBKR_CONFLICT_RETRY_MINUTES=1

# Probe is non-invasive: check whether IBKR became available again, but never
# request a competing session or force-disconnect the phone/desktop session.
IBKR_CONFLICT_PROBE_SECONDS=5
IBKR_FALLBACK_PROVIDER=schwab
STRICT_NO_SESSION_FIGHT=false

# In auto mode, weekends are reserved for cleanup/audit jobs. Use runtime
# override `ibkr-on` if a holiday/weekend manual data check is needed.
WEEKEND_MAINTENANCE_MODE=true

# Agent/runtime override. The mode file is ignored by git and is intended for
# short-lived commands such as "turn IBKR monitoring on for two hours".
RUNTIME_MODE_PATH=runtime/mode.json
AGENT_OVERRIDE_DEFAULT_TTL_MINUTES=120

# Schwab verifier. Store real tokens only in .env or runtime/, never in git.
SCHWAB_API_BASE_URL=https://api.schwabapi.com
SCHWAB_TOKEN_FILE=runtime/schwab-token.json
# Keep these values only in the local ignored .env. Never paste them into chat.
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
# Public callback registered exactly in the Schwab developer portal.
SCHWAB_CALLBACK_URL=https://schwab-auth.example.com/oauth/callback
SCHWAB_OAUTH_BIND_HOST=127.0.0.1
SCHWAB_OAUTH_BIND_PORT=8183
SCHWAB_OAUTH_STATE_FILE=runtime/schwab-oauth-state.json
SCHWAB_OAUTH_STATE_TTL_SECONDS=900
SCHWAB_GATEWAY_BIND_HOST=127.0.0.1
SCHWAB_GATEWAY_BIND_PORT=8184
# Collectors use this localhost-only gateway; it is never routed by Cloudflare.
SCHWAB_GATEWAY_URL=http://127.0.0.1:8184
SCHWAB_STREAMING_MODE=off
SCHWAB_STREAM_VALIDATION_FUTURES=NQ,RTY,YM
# Copy exactly one current ES futures-option symbol from thinkorswim; empty disables the probe.
SCHWAB_STREAM_FUTURES_OPTION_PROBE=
# Legacy verifier fallback only. Production should leave this empty so the
# refresh-capable token-file session is used.
SCHWAB_ACCESS_TOKEN=
SCHWAB_VERIFY_INDEXES='$SPX,$VIX,$VIX1D,$VIX9D,$VIX3M,$VVIX,$SKEW,$NDX,$RUT,$DJI,$DJU'
SCHWAB_VERIFY_EQUITIES=SPY,QQQ,IWM,DIA,HYG,LQD,TLT,IEF,SHY,UUP,GLD,USO,RSP,XLU
SCHWAB_VERIFY_FUTURES=/ES,/MES
SCHWAB_VERIFY_OPTION_CHAINS=SPX,XSP,SPY,QQQ,IWM
SCHWAB_OPTION_CHAIN_STRIKE_COUNT=10
SCHWAB_QUOTE_FIELDS=quote,reference,extended,regular
SCHWAB_REQUEST_TIMEOUT_SECONDS=12
SCHWAB_HTTP_REQUESTS_PER_MINUTE=120
SCHWAB_HTTP_MAX_RETRIES=3
SCHWAB_HTTP_RETRY_BASE_SECONDS=0.5
SCHWAB_HTTP_RETRY_MAX_SECONDS=8
SCHWAB_HTTP_RETRY_AFTER_MAX_SECONDS=30
# SPY/ETF option chains for wall confluence (requires Schwab OAuth token)
SCHWAB_COLLECT_QUOTES='$SPX,$XSP,$VIX,$VIX1D,$VIX9D,$VIX3M,$VVIX,$SKEW,$NDX,$RUT,$DJI,$DJU,SPY,QQQ,IWM,DIA,HYG,LQD,TLT,IEF,SHY,UUP,GLD,USO,RSP,XLU,/ES,/MES'
SCHWAB_COLLECT_CHAINS=SPX,XSP,SPY,QQQ,IWM

# 当日事件标签,逗号分隔(fomc/cpi/nfp/opex/jpm_collar/month_end...),盘前人工维护
MICOPEDIA_EVENT_TAGS=

# Hyperliquid public info endpoint. No API key required.
# xyz:SP500 is the active S&P 500-like HIP-3 perp found via perpDexs/metaAndAssetCtxs.
HYPERLIQUID_API_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_DEX=xyz
HYPERLIQUID_COIN=xyz:SP500
HYPERLIQUID_REQUEST_TIMEOUT_SECONDS=10
HYPERLIQUID_INCLUDE_BOOK=true
HYPERLIQUID_INCLUDE_TRADES=true
HYPERLIQUID_BOOK_DEPTH_LEVELS=5
HYPERLIQUID_LARGE_TRADE_NOTIONAL_THRESHOLD=100000
HYPERLIQUID_PROXY_BASIS_WARN_BPS=50
HYPERLIQUID_PROXY_BASIS_BLOCK_BPS=100
# Wider basis thresholds when the only usable anchor is a future (ES/MES carries
# natural roll/dividend basis versus cash SPX).
HYPERLIQUID_PROXY_FUTURES_BASIS_WARN_BPS=80
HYPERLIQUID_PROXY_FUTURES_BASIS_BLOCK_BPS=150

# Polymarket public Gamma API. Research-only context; never direct alerts or Kelly sizing.
POLYMARKET_GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_REQUEST_TIMEOUT_SECONDS=12
POLYMARKET_SEARCH_TERMS=SPY,Fed decision,CPI,FOMC,Powell,NFP
POLYMARKET_EVENT_SLUGS=
POLYMARKET_MARKET_SLUGS=
POLYMARKET_MAX_RESULTS_PER_QUERY=5
POLYMARKET_MAX_MARKETS_PER_RUN=80
POLYMARKET_MIN_LIQUIDITY=0
POLYMARKET_MIN_VOLUME_24H=0
POLYMARKET_MIN_RELEVANCE_SCORE=0.35
POLYMARKET_INCLUDE_CLOSED=false
POLYMARKET_USER_AGENT=Mozilla/5.0 spx-spark research collector

# Maintenance. Daily timer runs dry-run; weekly timer runs prune (executes
# deletion only when disk usage crosses MAINTENANCE_PRUNE_PCT, audit-only
# otherwise) plus outbox/review-audit retention.
# latest/ and *.lock files are never deleted. preserved/ alert windows use
# MAINTENANCE_ALERT_WINDOW_RETENTION_DAYS (default 60) instead of raw retention.
MAINTENANCE_DATA_ROOT=data
MAINTENANCE_LOGS_ROOT=logs
MAINTENANCE_OUTPUT_ROOT=logs
MAINTENANCE_DATA_BUDGET_GB=80
MAINTENANCE_RAW_RETENTION_DAYS=10
MAINTENANCE_ALERT_WINDOW_RETENTION_DAYS=60
MAINTENANCE_FEATURE_1S_RETENTION_DAYS=30
MAINTENANCE_FEATURE_5S_RETENTION_DAYS=90
MAINTENANCE_LOG_RETENTION_DAYS=14
MAINTENANCE_TRASH_RETENTION_DAYS=7
MAINTENANCE_OUTBOX_RETENTION_DAYS=30
MAINTENANCE_REVIEW_AUDIT_RETENTION_DAYS=30
MAINTENANCE_ALERT_COOLDOWN_HOURS=24
MAINTENANCE_WARN_PCT=70
MAINTENANCE_COMPACT_PCT=80
MAINTENANCE_DEGRADED_PCT=85
MAINTENANCE_PRUNE_PCT=90
MAINTENANCE_CRITICAL_PCT=95

# Normalized quote storage. Defaults inherit MAINTENANCE_DATA_ROOT.
MARKET_DATA_DATA_ROOT=data
MARKET_DATA_LATEST_STATE_PATH=data/latest/state.json
MARKET_DATA_RAW_FILE_NAME=quotes.jsonl
MARKET_DATA_INCLUDE_RAW_PAYLOAD=false
MARKET_DATA_LATEST_STALE_AFTER_SECONDS=15
# Schwab is primary after live OAuth, quote, and option-chain acceptance; IBKR remains fallback.
MARKET_DATA_PROVIDER_PRIORITY=schwab,ibkr,hyperliquid,polymarket,internal,mock,unknown
# Storage-layer slow index labels use canonical ids (equity:QQQ not stock:QQQ).
MARKET_DATA_SLOW_INDEX_STALE_AFTER_SECONDS=900
MARKET_DATA_SLOW_INDEX_LABELS=index:VIX,index:VIX1D,index:VIX9D,index:VIX3M,index:VVIX,index:SKEW,equity:QQQ,equity:IWM,equity:DIA,equity:HYG,equity:LQD,equity:TLT,equity:IEF,equity:SHY,equity:UUP,equity:GLD,equity:USO,equity:RSP,equity:XLU

# IV surface snapshots. The 24h service writes one snapshot every 5 minutes by default.
IV_SURFACE_LATEST_PATH=data/latest/iv_surface.json
IV_SURFACE_RAW_FILE_NAME=snapshots.jsonl
IV_SURFACE_WIDE_QUOTE_SPREAD_BPS=250

# Post-close SPX/SPXW review. The Hermes export path is a Markdown fragment
# intended for the local Hermes daily report to append.
SPX_REVIEW_OUTPUT_DIR=data/reports/spx_options_review
SPX_REVIEW_LATEST_MARKDOWN_PATH=data/latest/spx_options_review.md
SPX_REVIEW_HERMES_EXPORT_DIR=/home/ubuntu/research/finance/daily/spx-options-review
SPX_REVIEW_LLM_ENABLED=false
SPX_REVIEW_LLM_PROVIDER=deepseek
SPX_REVIEW_LLM_MODEL=deepseek-v4-pro
SPX_REVIEW_LLM_URL=https://api.deepseek.com/v1/chat/completions
SPX_REVIEW_LLM_ENV_FILE=/home/ubuntu/.hermes/.env
SPX_REVIEW_LLM_TIMEOUT_SECONDS=120
SPX_REVIEW_LLM_MAX_TOKENS=2200
# Structured completeness gate; every required check must pass for complete.
SPX_REVIEW_MIN_INDEX_BUCKET_RATIO=0.90
SPX_REVIEW_MAX_EDGE_GAP_MINUTES=15
SPX_REVIEW_MIN_INDEX_LIVE_RATIO=0.95
SPX_REVIEW_MIN_FRONT_OPTION_CONTRACTS=20
SPX_REVIEW_MIN_FRONT_OPTION_STRIKES=10
SPX_REVIEW_MIN_FRONT_OPTION_STRIKE_SPAN=50
SPX_REVIEW_MIN_OPTION_USABLE_RATIO=0.90
SPX_REVIEW_MIN_OPTION_IV_RATIO=0.80
SPX_REVIEW_MIN_SURFACE_BUCKET_RATIO=0.60
SPX_REVIEW_MIN_SURFACE_IV_RATIO=0.50
SPX_REVIEW_MIN_SURFACE_GAMMA_RATIO=0.50

# DeepSeek writer for scheduled pushes (order map / status report / morning map).
# Falls back to the OpenClaw agent, then the deterministic template.
SPX_PUSH_LLM_ENABLED=true
SPX_PUSH_LLM_MODEL=deepseek-v4-pro
SPX_PUSH_LLM_URL=https://api.deepseek.com/v1/chat/completions
SPX_PUSH_LLM_ENV_FILE=/home/ubuntu/.hermes/.env
SPX_PUSH_LLM_TIMEOUT_SECONDS=90
SPX_PUSH_LLM_MAX_TOKENS=12800

# 24h service loop. IBKR is disabled by default to avoid taking the broker session.
SPX_SERVICE_ENABLE_HYPERLIQUID=true
SPX_SERVICE_ENABLE_POLYMARKET=false
SPX_SERVICE_ENABLE_IBKR=false
SPX_SERVICE_ENABLE_IV_SURFACE=true
# Explicit production opt-in after replay/shadow verification.
SPX_SERVICE_ENABLE_INTRADAY_SHOCK=false
# Research-only SPXW 0DTE higher-Greeks sampling; never notifies or places orders.
SPX_SERVICE_ENABLE_GREEK_SHADOW=false
SPX_SERVICE_ENABLE_ALERTS=true
SPX_SERVICE_HYPERLIQUID_INTERVAL_SECONDS=30
SPX_SERVICE_POLYMARKET_INTERVAL_SECONDS=60
SPX_SERVICE_IBKR_INTERVAL_SECONDS=60
SPX_SERVICE_IBKR_SKIP_OPTIONS=false
SPX_SERVICE_IV_SURFACE_INTERVAL_SECONDS=300
# Lightweight SPX+ES path monitor; deterministic shock/reclaim alerts bypass LLM veto.
SPX_SERVICE_INTRADAY_SHOCK_INTERVAL_SECONDS=5
SPX_SERVICE_GREEK_SHADOW_INTERVAL_SECONDS=60
SPX_SERVICE_ALERT_INTERVAL_SECONDS=30
SPX_SERVICE_HEARTBEAT_SECONDS=60
SPX_SERVICE_OUTPUT_TAIL_CHARS=1200
SPX_SERVICE_TASK_TIMEOUT_SECONDS=120
# Tasks run concurrently (one in-flight instance per task); a hung IBKR cycle
# no longer delays alert/Hyperliquid cadence.
SPX_SERVICE_MAX_CONCURRENT_TASKS=4
# SPY option chain collector via Schwab (requires OAuth token file ready)
# Main Schwab quote + chain collector; name retained for service compatibility.
# Keep false: the dedicated spx-spark-schwab-marketdata.service already collects
# (see config/runtime.yaml collection.service_loop_enabled). true here makes the
# 24h loop double-write state.json and burn the Schwab request budget twice.
SPX_SERVICE_SCHWAB_CHAINS_ENABLED=false
SPX_SERVICE_SCHWAB_CHAINS_INTERVAL_SECONDS=15

# Alert notification. Disabled by default.
# Delivery is Bark (lockscreen) + Feishu (IM reading surface).
# OpenClaw Weixin message send is removed from the fan-out; leave CHANNEL/TARGET empty.
# OpenClaw agent remains an optional DeepSeek fallback for analysis only.
ALERT_NOTIFY_ENABLED=false
ALERT_NOTIFY_MIN_SEVERITY=high
ALERT_NOTIFY_COOLDOWN_SECONDS=900
# 幅度桶类告警(skew/IV/价格异动/浮盈亏)同 kind+标的 1 小时限 1 条;桶跳>=2档、方向翻转或 critical 可突破
ALERT_NOTIFY_KIND_RATE_LIMIT_SECONDS=3600
# gamma 状态需持续 10 分钟才告警(防 4 分钟翻面刷屏)
ALERT_GAMMA_REGIME_HYSTERESIS_SECONDS=600
# Quiet (overnight/Asia) movement pushes: bar = max(0.35 x day EM, floor).
ALERT_MOVE_QUIET_FLOOR_BPS=15
ALERT_MOVE_HIGH_SEVERITY_EM_FRACTION=0.35
ALERT_NOTIFY_STATE_PATH=data/latest/alert_notify_state.json
# Append-only 0600 JSONL with reviewer/direct candidates, raw verdict and delivery outcome.
ALERT_NOTIFY_REVIEW_AUDIT_PATH=
ALERT_NOTIFY_OPENCLAW_ENABLED=false
ALERT_NOTIFY_OPENCLAW_COMMAND=openclaw
ALERT_NOTIFY_OPENCLAW_CHANNEL=
ALERT_NOTIFY_OPENCLAW_ACCOUNT=
ALERT_NOTIFY_OPENCLAW_TARGET=
ALERT_NOTIFY_OPENCLAW_DRY_RUN=true
ALERT_NOTIFY_OPENCLAW_TIMEOUT_SECONDS=20
ALERT_NOTIFY_OPENCLAW_AGENT_ENABLED=false
# The agent runs analysis-only (no openclaw --deliver). When DELIVER=true, only
# replies starting with 需要看盘: that pass the scope gate are forwarded via
# Feishu/Bark; 不需要推送 verdicts are recorded and start the cooldown.
ALERT_NOTIFY_OPENCLAW_AGENT_DELIVER=false
ALERT_NOTIFY_OPENCLAW_AGENT_NAME=main
ALERT_NOTIFY_OPENCLAW_AGENT_MODEL=openai/gpt-5.3-codex-spark
ALERT_NOTIFY_OPENCLAW_AGENT_SESSION_KEY=spx-spark-alerts
ALERT_NOTIFY_OPENCLAW_AGENT_THINKING=high
ALERT_NOTIFY_OPENCLAW_AGENT_TIMEOUT_SECONDS=180

# Fast reviewer before any OpenClaw/Codex agent. Weak or non-time-sensitive
# alerts are cooldown-marked by rules and do not spend LLM calls.
ALERT_NOTIFY_DEEPSEEK_ENABLED=true
ALERT_NOTIFY_DEEPSEEK_DELIVER=true
ALERT_NOTIFY_DEEPSEEK_MODEL=deepseek-v4-flash
ALERT_NOTIFY_DEEPSEEK_URL=https://api.deepseek.com/v1/chat/completions
ALERT_NOTIFY_DEEPSEEK_ENV_FILE=/home/ubuntu/.hermes/.env
ALERT_NOTIFY_DEEPSEEK_TIMEOUT_SECONDS=30
ALERT_NOTIFY_DEEPSEEK_MAX_TOKENS=6400
ALERT_NOTIFY_DEEPSEEK_OUTPUT_MAX_CHARS=6400
ALERT_NOTIFY_DEEPSEEK_TEMPERATURE=0.1
ALERT_REVIEW_MIN_TIME_SENSITIVE_SCORE=30

# Bark (iOS push, https://bark.day.app).
# Lane doctrine:
#   - Bark main: ALL pushes — trading (short lockscreen + optional markdown
#     detail) AND ops/engineering (IBKR session, data degradation, channel
#     failures) in bark_ops_group.
#   - Bark friend: trading only, short plain text.
#   - Feishu: trading reading surface (interactive markdown cards); ops stay out.
ALERT_NOTIFY_BARK_ENABLED=false
ALERT_NOTIFY_BARK_URL=https://api.day.app/YOUR_BARK_DEVICE_KEY
ALERT_NOTIFY_BARK_GROUP=spx-spark
ALERT_NOTIFY_BARK_OPS_GROUP=spx-ops
ALERT_NOTIFY_BARK_LEVEL=timeSensitive
ALERT_NOTIFY_BARK_TIMEOUT_SECONDS=10
ALERT_NOTIFY_BARK_MARKDOWN_ENABLED=true
# Max characters per Bark message before truncation (Bark rejects oversized
# payloads with HTTP 413; long CJK reports must be clipped, default 1500).
ALERT_NOTIFY_BARK_MAX_CHARS=1500
# Friend Bark channel: trading content only (order map / status / morning map /
# post-close review / reviewed market alerts). Ops noise (data degradation,
# IBKR session drops, token expiry) is never routed here.
ALERT_NOTIFY_BARK_FRIEND_ENABLED=false
ALERT_NOTIFY_BARK_FRIEND_URL=https://api.day.app/FRIEND_BARK_DEVICE_KEY
# Feishu custom-bot webhook (interactive cards). Leave disabled until URL set.
ALERT_NOTIFY_FEISHU_ENABLED=false
ALERT_NOTIFY_FEISHU_WEBHOOK_URL=
ALERT_NOTIFY_FEISHU_SECRET=
ALERT_NOTIFY_FEISHU_TIMEOUT_SECONDS=10
# 直推事件(持仓/系统/盘外vol)先过 DeepSeek 写手改写成中文,失败自动回退原始模板
ALERT_NOTIFY_DIRECT_PUSH_LLM_ENABLED=true
# Leave empty to use the default under MARKET_DATA_DATA_ROOT/latest/.
ALERT_NOTIFY_MISSED_QUEUE_PATH=
# Leave empty to use the content-free SQLite receipt ledger under data/ledger/.
ALERT_NOTIFY_DELIVERY_RECEIPT_PATH=
# Unified per-sink delivery outbox. Message bodies are stored in an
# owner-readable SQLite file so failed Bark/Feishu targets can be retried
# independently without resending a sink that already acknowledged delivery.
ALERT_NOTIFY_DELIVERY_OUTBOX_ENABLED=true
ALERT_NOTIFY_DELIVERY_OUTBOX_PATH=
ALERT_NOTIFY_DELIVERY_OUTBOX_MAX_ATTEMPTS=8
ALERT_NOTIFY_DELIVERY_OUTBOX_RETRY_SCHEDULE_SECONDS=15,60,300,900
ALERT_NOTIFY_DELIVERY_OUTBOX_DEAD_LETTER_AFTER_SECONDS=86400
ALERT_NOTIFY_DELIVERY_OUTBOX_CLAIM_STALE_AFTER_SECONDS=180
ALERT_NOTIFY_DELIVERY_OUTBOX_RECOVERY_BATCH_SIZE=50
# Temporary rollback shadow; disable after the SQLite rollout soak succeeds.
ALERT_NOTIFY_DELIVERY_OUTBOX_LEGACY_SHADOW_ENABLED=true
ALERT_NOTIFY_OUTBOX_MAX_ATTEMPTS=
ALERT_NOTIFY_OUTBOX_RETRY_BASE_SECONDS=
ALERT_NOTIFY_OUTBOX_RETRY_MAX_SECONDS=
ALERT_NOTIFY_OUTBOX_CLAIM_STALE_AFTER_SECONDS=

# Deterministic RTH SPX+ES shock/reversal monitor. Both anchors must be live,
# fresh and synchronized; confirmed events bypass reviewer veto.
ALERT_INTRADAY_SHOCK_STATE_PATH=
ALERT_INTRADAY_SHOCK_1M_SECONDS=60
ALERT_INTRADAY_SHOCK_3M_SECONDS=180
ALERT_INTRADAY_SHOCK_1M_BPS=20
ALERT_INTRADAY_SHOCK_3M_BPS=35
ALERT_INTRADAY_SHOCK_ES_CONFIRM_RATIO=0.50
ALERT_INTRADAY_SHOCK_SPX_MAX_AGE_SECONDS=15
ALERT_INTRADAY_SHOCK_ES_MAX_AGE_SECONDS=10
ALERT_INTRADAY_SHOCK_MAX_ANCHOR_SKEW_SECONDS=5
ALERT_INTRADAY_RECLAIM_WINDOW_SECONDS=300
ALERT_INTRADAY_RECLAIM_FRACTION=0.60
ALERT_INTRADAY_RECLAIM_ES_FRACTION=0.40
# After the first 60%/40% cross, the next fresh synchronized sample may hold
# above 55%/35%; this confirms quickly without requiring an identical tick.
ALERT_INTRADAY_RECLAIM_HOLD_FRACTION=0.55
ALERT_INTRADAY_RECLAIM_ES_HOLD_FRACTION=0.35
ALERT_INTRADAY_RECLAIM_CONFIRM_SAMPLES=2
ALERT_INTRADAY_EVENT_EXPIRY_SECONDS=600
ALERT_INTRADAY_COMPLETION_HOLD_SECONDS=60
# An expired one-way event cannot re-alert every 10 minutes. It must recover
# 40% and remain neutral for five minutes before a fresh event may arm.
ALERT_INTRADAY_REARM_RECOVERY_FRACTION=0.40
ALERT_INTRADAY_REARM_NEUTRAL_SECONDS=300
ALERT_INTRADAY_DELIVERY_RETRY_SECONDS=30
# Symmetric 0DTE Call path confirmation. Levels are frozen before the move;
# Gamma is context only and never votes on direction.
ALERT_INTRADAY_CALL_LEVEL_BUFFER_POINTS=3
ALERT_INTRADAY_CALL_CONFIRM_SAMPLES=2
ALERT_INTRADAY_CALL_CONFIRM_WINDOW_SECONDS=60
ALERT_INTRADAY_CALL_SOURCE_TTL_SECONDS=300
ALERT_INTRADAY_CALL_BIAS_TTL_SECONDS=300
ALERT_INTRADAY_CALL_COOLDOWN_SECONDS=900
ALERT_INTRADAY_CALL_STRUCTURE_GRACE_SECONDS=30
ALERT_INTRADAY_CALL_RETRY_SECONDS=30
ALERT_INTRADAY_CALL_LEVEL_DRIFT_TOLERANCE_POINTS=5
ALERT_INTRADAY_CALL_ES_CONFIRM_RATIO=0.50
ALERT_INTRADAY_CALL_ES_HOLD_TOLERANCE_BPS=1
# Append-only shock/reclaim outcome telemetry: directional MFE/MAE and raw
# SPX path high/low at 5/15/30 minutes. Raw event ids are never persisted.
ALERT_INTRADAY_OUTCOME_STATE_PATH=
# Optional override. Default is a daily date={trading_date} partition under
# data/features. When the data platform is enabled, the same outcomes are also
# written to the long-lived SQLite research ledger.
ALERT_INTRADAY_OUTCOME_RESULTS_PATH=
ALERT_INTRADAY_OUTCOME_RETENTION_SECONDS=7200

# Local operational ledger + immutable Parquet lake + DuckDB research views.
# Shadow telemetry is fail-open. Raw deletion remains disabled by default and,
# when explicitly enabled, only removes sources after verified compaction plus
# the configured rollback grace.
DATA_PLATFORM_ENABLED=false
DATA_PLATFORM_LEDGER_PATH=
DATA_PLATFORM_FALLBACK_SPOOL_PATH=
DATA_PLATFORM_FALLBACK_SPOOL_MAX_BYTES=67108864
DATA_PLATFORM_SQLITE_BUSY_TIMEOUT_MS=250
DATA_PLATFORM_COMPACTION_MIN_AGE_SECONDS=300
DATA_PLATFORM_RAW_DELETE_ENABLED=false
DATA_PLATFORM_RAW_DELETE_GRACE_HOURS=72
DATA_PLATFORM_WRITER_VERSION=spx-spark-v1

# Weixin keepalive service/timer/script has been removed; Feishu is the IM
# reading surface. Do not re-add OPENCLAW_WEIXIN_KEEPALIVE_* here.

# Preferred production path: DeepSeek reviews alerts and delivers to Feishu/Bark.
# Keep OpenClaw agent and Codex CLI disabled in production; enable only as
# explicit fallback/debug paths.
ALERT_NOTIFY_CODEX_ENABLED=false
ALERT_NOTIFY_CODEX_DELIVER=true
ALERT_NOTIFY_CODEX_COMMAND=codex
ALERT_NOTIFY_CODEX_MODEL=gpt-5.3-codex-spark
ALERT_NOTIFY_CODEX_REASONING_EFFORT=high
ALERT_NOTIFY_CODEX_CWD=/home/ubuntu/spx-spark
ALERT_NOTIFY_CODEX_SANDBOX=read-only
ALERT_NOTIFY_CODEX_TIMEOUT_SECONDS=90
ALERT_NOTIFY_CODEX_OUTPUT_MAX_CHARS=1800
ALERT_NOTIFY_CODEX_REQUIRE_DELIVERY_CUE=true
ALERT_MIN_OPTION_LIVE_RATIO=0.5
ALERT_MAX_OPTION_QUOTE_AGE_MS=20000
ALERT_REQUIRE_OPTION_QUOTE_TIMESTAMPS=false
ALERT_MAX_IV_SURFACE_AGE_SECONDS=420
ALERT_BROKER_STATE_MAX_AGE_SECONDS=900
ALERT_SYSTEM_EVENTS_ENABLED=true
ALERT_SYSTEM_EVENT_STATE_PATH=data/latest/system_event_state.json
# Movement alerts are edge-triggered per threshold bucket; state lives here.
ALERT_MOVEMENT_STATE_PATH=data/latest/movement_state.json
ALERT_ALLOW_BROKER_UNAVAILABLE_PROXY_WATCH=true
ALERT_PROXY_FALLBACK_MOVE_BPS=30

# SPXW sampling planner.
SAMPLING_STRIKE_STEP=5
SAMPLING_WINDOW_POINTS=200
SAMPLING_HOT_WINDOW_POINTS=50
# 1DTE (next expiry) only gets ATM-vicinity lines; walls/GEX use 0DTE.
SAMPLING_NEXT_EXPIRY_WINDOW_POINTS=30
SAMPLING_NEXT_EXPIRY_HOT_WINDOW_POINTS=10
SAMPLING_GROUP_COUNT=4
SAMPLING_GROUP_INTERVAL_SECONDS=4
SAMPLING_DEGRADED_GROUP_COUNT=20
SAMPLING_DEGRADED_GROUP_INTERVAL_SECONDS=3
SAMPLING_GROUP_STRATEGY=interleaved
SAMPLING_HOT_HUMAN_CADENCE_SECONDS=8
SAMPLING_HOT_EXECUTION_CADENCE_SECONDS=2
SAMPLING_INCLUDE_NEXT_EXPIRY=true
SAMPLING_DEFAULT_MODE=human_alert
