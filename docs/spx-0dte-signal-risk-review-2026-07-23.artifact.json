        "label": "Raw versus semantic pricing-outcome statistics at the 2026-07-22 intent",
        "path": "data/features/pricing_outcomes/date=*/outcomes.jsonl",
        "query": {
          "engine": "production-equivalent Python audit",
          "id": "breakout-call-flip-high-stats-at-20260722T092205Z",
          "sql": "WITH eligible AS (SELECT *, horizons.\"300\".return_fraction AS return_fraction FROM read_json_auto('data/features/pricing_outcomes/date=*/outcomes.jsonl') WHERE touched = TRUE AND completed_at BETWEEN TIMESTAMP '2026-07-02 09:22:05.290029' AND TIMESTAMP '2026-07-22 09:22:05.290029' AND horizons.\"300\".return_fraction IS NOT NULL), ranked AS (SELECT *, ROW_NUMBER() OVER (PARTITION BY first_touch_at, contract_id, play ORDER BY completed_at, event_id, level_kind) AS semantic_rank FROM eligible), compared AS (SELECT 'raw_event_rows' AS method, return_fraction FROM eligible WHERE play = 'level_breakout_call' AND level_kind = 'flip_high' UNION ALL SELECT 'semantic_first_touch', return_fraction FROM ranked WHERE semantic_rank = 1 AND play = 'level_breakout_call' AND level_kind = 'flip_high') SELECT method, COUNT(*) AS sample_count, SUM(CASE WHEN return_fraction > 0 THEN 1 ELSE 0 END) AS wins, AVG(return_fraction) AS avg_return FROM compared GROUP BY method ORDER BY method",
          "description": "Compares legacy event-row counting with semantic first-touch/contract/play deduplication before grouping.",
          "executed_at": "2026-07-23T12:00:00+00:00",
          "language": "sql",
          "filters": [
            "as-of 2026-07-22T09:22:05.290029Z",
            "rolling 20 days",
            "touched outcomes only",
            "300-second option-mid return",
            "semantic identity = first_touch_at + contract_id + play",
            "deduplication occurs globally before play/level_kind grouping"
